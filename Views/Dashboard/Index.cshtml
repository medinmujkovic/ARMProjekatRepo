@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageHeading"] = "Dashboard";
    string? role = ViewBag.CurrentRole as string;
    bool canCreateCase = AppRole.CanCreateCase(role);
    bool canUploadEvidence = AppRole.CanUploadEvidence(role);
}

<section class="grid cards-grid">
    <div class="stat-card">
        <span>Ukupno predmeta</span>
        <strong>@Model.TotalCases</strong>
        <small>Sudski predmeti u sistemu</small>
    </div>
    <div class="stat-card">
        <span>Ukupno dokaza</span>
        <strong>@Model.TotalEvidence</strong>
        <small>Digitalni dokazi povezani sa predmetima</small>
    </div>
    <div class="stat-card">
        <span>Provjereni dokazi</span>
        <strong>@Model.VerifiedEvidence</strong>
        <small>Dokazi sa sačuvanim SHA-256 hashom</small>
    </div>
    <div class="stat-card">
        <span>Korisničke uloge</span>
        <strong>3</strong>
        <small>Glavni inspektor, inspektor i sudija</small>
    </div>
</section>

<section class="content-grid">
    <div class="panel">
        <div class="panel-header">
            <div>
                <h2>Nedavni sudski predmeti</h2>
                <p>Pregled zadnjih evidentiranih predmeta u sistemu.</p>
            </div>
            <a asp-controller="Cases" asp-action="Index" class="secondary-button">Svi predmeti</a>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Broj predmeta</th>
                        <th>Naziv</th>
                        <th>Status</th>
                        <th>Sud</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.RecentCases)
                {
                    <tr>
                        <td>@item.CaseNumber</td>
                        <td>@item.Title</td>
                        <td><span class="status-pill">@item.Status</span></td>
                        <td>@item.CourtName</td>
                        <td><a asp-controller="Cases" asp-action="Details" asp-route-id="@item.Id">Otvori</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <aside class="panel quick-panel">
        <h2>Prava pristupa</h2>
        <p>Funkcionalnosti se prikazuju u skladu sa prijavljenom ulogom.</p>

        <div class="access-item enabled">Prijava u sistem</div>
        <div class="access-item enabled">Pregled dashboarda</div>
        <div class="access-item @(canCreateCase ? "enabled" : "disabled")">Kreiranje sudskog predmeta</div>
        <div class="access-item enabled">Pregled sudskih predmeta</div>
        <div class="access-item @(canUploadEvidence ? "enabled" : "disabled")">Dodavanje digitalnih dokaza</div>
        <div class="access-item enabled">SHA-256 provjera</div>

        <div class="quick-actions">
            @if (canCreateCase)
            {
                <a asp-controller="Cases" asp-action="Create" class="primary-button">Novi predmet</a>
            }
            <a asp-controller="Cases" asp-action="Index" class="secondary-button">Pregled predmeta</a>
        </div>
    </aside>
</section>
