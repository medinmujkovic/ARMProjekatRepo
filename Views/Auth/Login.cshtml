@{
    ViewData["Title"] = "Prijava";
    Layout = "_Layout";
}

<section class="login-page">
    <div class="login-info-panel">
        <div class="system-badge">SIS</div>
        <h1>Sudski informacioni sistem</h1>
        <p>
            Pojednostavljena aplikacija za sigurnu obradu sudskih predmeta i digitalnih dokaza,
            sa jasno odvojenim pravima pristupa prema ulozi korisnika.
        </p>
        <div class="security-list">
            <span>SHA-256 provjera fajlova</span>
            <span>Ograničenje neuspješnih prijava</span>
            <span>Hashirane lozinke</span>
            <span>Kontrola pristupa prema ulozi</span>
        </div>
    </div>

    <div class="login-card">
        <h2>Prijava korisnika</h2>
        <p>Unesite korisničke podatke za pristup sistemu.</p>

        @if (ViewBag.Error is string error)
        {
            <div class="alert alert-error">@error</div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post" class="form-stack">
            @Html.AntiForgeryToken()
            <label>
                Korisničko ime
                @* FIX #15 (A05): Dodan maxlength atribut — sprječava prekomjerno veliki unos *@
                <input type="text" name="username" autocomplete="username" required maxlength="100" />
            </label>
            <label>
                Lozinka
                <input type="password" name="password" autocomplete="current-password" required maxlength="256" />
            </label>
            <button type="submit" class="primary-button full-width">Prijava</button>
        </form>

        @* FIX #15 (A09 - Security Logging & Monitoring / Sensitive Data Exposure):
           Demo korisnici i lozinke su uklonjeni iz HTML-a.
           Prikazivanje plaintext kredencijala u produkcijskom UI-u je kritičan propust —
           svaki korisnik koji pogleda HTML izvorni kod vidio bi sve lozinke. *@
    </div>
</section>
