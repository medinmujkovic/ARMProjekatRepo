{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Security": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "MaxUploadSizeMb": 10,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".txt", ".docx" ]
  }
}